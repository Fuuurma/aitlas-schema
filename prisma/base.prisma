// Aitlas Base Schema - Prisma
// All tables use snake_case naming

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Auth
// ============================================

model User {
  id             String    @id @db.VarChar(255)
  name           String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  email_verified Boolean   @default(false) @map("email_verified")
  image          String?   @db.VarChar(255)
  created_at     DateTime  @default(now()) @map("created_at")
  updated_at     DateTime  @updatedAt @map("updated_at")

  // Credits
  compute_credits Int      @default(100) @map("compute_credits")
  plan_tier       PlanTier @default(FREE) @map("plan_tier")

  // Relations
  sessions        Session[]
  accounts        Account[]
  api_keys        ApiKey[]
  tasks           Task[]
  agents          UserAgent[]
  credit_ledger   CreditLedgerEntry[]

  @@map("users")
}

model Session {
  id           String   @id @db.VarChar(255)
  user_id      String   @map("user_id")
  expires_at   DateTime @map("expires_at")
  created_at   DateTime @default(now()) @map("created_at")
  updated_at   DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("sessions")
}

model Account {
  id                String   @id @db.VarChar(255)
  user_id           String   @map("user_id")
  provider_type     String   @map("provider_type")
  provider_id       String   @map("provider_id")
  provider_account_id String @map("provider_account_id")
  created_at        DateTime @default(now()) @map("created_at")
  updated_at        DateTime @updatedAt @map("updated_at")

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("accounts")
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

// ============================================
// API Keys
// ============================================

model ApiKey {
  id          String   @id @db.VarChar(255)
  user_id     String   @map("user_id")
  name        String   @db.VarChar(255)
  key_hash    String   @map("key_hash") @db.VarChar(255)
  prefix      String   @db.VarChar(8)
  last_used   DateTime? @map("last_used")
  created_at  DateTime @default(now()) @map("created_at")
  revoked     Boolean  @default(false)

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("api_keys")
}

// ============================================
// Credits
// ============================================

model CreditLedgerEntry {
  id          String   @id @db.VarChar(255)
  user_id     String   @map("user_id")
  delta       Int
  balance     Int
  reason      String   @db.VarChar(255)
  task_id     String?  @map("task_id") @db.VarChar(255)
  created_at  DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("credit_ledger")
}

// ============================================
// Tasks
// ============================================

model Task {
  id          String     @id @db.VarChar(255)
  user_id     String     @map("user_id")
  agent_id    String?    @map("agent_id") @db.VarChar(255)
  status      TaskStatus @default(pending)
  prompt      String     @db.Text
  result      String?    @db.Text
  error       String?    @db.Text
  created_at  DateTime   @default(now()) @map("created_at")
  updated_at  DateTime   @updatedAt @map("updated_at")
  completed_at DateTime? @map("completed_at")

  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  steps       TaskStep[]
  tool_calls  ToolCall[]

  @@index([user_id])
  @@index([status])
  @@map("tasks")
}

model TaskStep {
  id          String   @id @db.VarChar(255)
  task_id     String   @map("task_id")
  step_number Int      @map("step_number")
  action      String   @db.VarChar(255)
  input       String?  @db.Text
  output      String?  @db.Text
  created_at  DateTime @default(now()) @map("created_at")

  task        Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@map("task_steps")
}

model ToolCall {
  id          String   @id @db.VarChar(255)
  task_id     String   @map("task_id")
  tool_name   String   @map("tool_name") @db.VarChar(255)
  arguments   String   @db.Text
  result      String?  @db.Text
  created_at  DateTime @default(now()) @map("created_at")

  task        Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@map("tool_calls")
}

enum TaskStatus {
  pending
  running
  completed
  failed
  cancelled
}

// ============================================
// Agents
// ============================================

model UserAgent {
  id           String   @id @db.VarChar(255)
  user_id      String   @map("user_id")
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  system_prompt String? @map("system_prompt") @db.Text
  model        String   @default("gpt-4o") @db.VarChar(255)
  created_at   DateTime @default(now()) @map("created_at")
  updated_at   DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("user_agents")
}